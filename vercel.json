{
  "buildCommand": "python manage.py collectstatic --noinput",
  "builds": [
    { "src": "staticfiles/**", "use": "@vercel/static" },
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/staticfiles/$1" },
    { "src": "/(.*)", "dest": "api/index.py" }
  ]
}